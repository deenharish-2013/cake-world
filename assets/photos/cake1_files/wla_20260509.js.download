/*login modal otp validation js*/
// ===== PRODUCTION-READY: iOS Safari OTP Validation Fix =====
// Robust mechanism to prevent multiple OTP validation calls on all devices
// Especially optimized for iOS Safari autofill behavior

// Use timestamp-based debounce for more reliable duplicate prevention
var isValidatingOTP = false;
var lastOTPValidationTime = 0;
var OTP_VALIDATION_COOLDOWN = 3000; // 3 seconds cooldown between validations
var otpValidationInProgress = false; // Track if AJAX is in progress

// Note: isIOSSafari and isIOS are defined at the top of the file for early availability

/**
 * Check if OTP validation can proceed (prevents duplicate calls)
 * Enhanced for iOS Safari auto-fill - works for all iOS versions
 * Uses both flag and timestamp for robust protection
 */
function canValidateOTP() {
    var now = Date.now();
    
    // Check if validation is in progress (primary check)
    if (isValidatingOTP || otpValidationInProgress) {
        return false;
    }
    
    // Check timestamp-based cooldown (prevents rapid-fire calls)
    if (lastOTPValidationTime > 0 && (now - lastOTPValidationTime) < OTP_VALIDATION_COOLDOWN) {
        return false;
    }
    
    // Additional check: Ensure OTP input is not disabled
    var $otpInput = $('#OTP');
    if ($otpInput.length && $otpInput.prop('disabled')) {
        return false;
    }
    
    return true;
}

/**
 * Set validation lock with timestamp
 */
function setOTPValidationLock() {
    isValidatingOTP = true;
    otpValidationInProgress = true;
    lastOTPValidationTime = Date.now();
}

/**
 * Release validation lock
 * @param {boolean} keepCooldown - If true, maintains cooldown period
 */
function releaseOTPValidationLock(keepCooldown) {
    isValidatingOTP = false;
    otpValidationInProgress = false;
    
    // If not keeping cooldown, allow immediate re-validation (for error cases)
    if (!keepCooldown) {
        lastOTPValidationTime = 0;
    }
}

function handleOTPInput(event, pId) {
    checkOTPInput(pId);
}

function checkOTPInput(pId) {
    try {
        var $otpInput = $('#OTP');
        var $submitButton = $('#validateOTP');
        var otpValue = $otpInput.val();

        // Check if input is exactly 6 digits
        if (otpValue && otpValue.length === 6 && /^\d{6}$/.test(otpValue)) {
            $submitButton.removeClass('disable');
            // For iOS Safari only, do NOT auto-submit — user must tap Verify
            // isIOS is intentionally excluded so Chrome/Firefox on iOS can auto-submit
            if (isIOSSafari) {
                return;
            }
            // For all other browsers, allow auto-submit as before
            if (canValidateOTP()) {
                setOTPValidationLock();
                
                // Disable input immediately to prevent duplicate submissions
                $otpInput.prop('disabled', true);
                $submitButton.addClass('disable');
                setTimeout(function() {
                    try {
                        // Double-check lock before validating
                        if (canValidateOTP() || isValidatingOTP) {
                            validateOTP(pId);
                        } else {
                            // Lock was released, re-enable input
                            $otpInput.prop('disabled', false);
                            $submitButton.removeClass('disable');
                            releaseOTPValidationLock(false);
                        }
                    } catch (e) {
                        console.error('OTP check timeout error:', e);
                        $otpInput.prop('disabled', false);
                        $submitButton.removeClass('disable');
                        releaseOTPValidationLock(false);
                    }
                }, 50);
                setTimeout(function() {
                    try {
                        if (!$otpInput.prop('disabled') || !isValidatingOTP) {
                            $otpInput.prop('disabled', false);
                            if (otpValue && otpValue.length === 6) {
                                $submitButton.removeClass('disable');
                            }
                        }
                    } catch (e) {
                        console.error('OTP re-enable timeout error:', e);
                    }
                }, 3000);
            }
        } else {
            $submitButton.addClass('disable');
        }
    } catch (e) {
        console.error('OTP input check error:', e);
        releaseOTPValidationLock(false);
        $('#OTP').prop('disabled', false);
    }
}

function submitOTP(pId) {
    // Prevent multiple API calls from manual submission
    if (canValidateOTP()) {
        setOTPValidationLock();
        
        // Small delay for iOS Safari
        if (isIOSSafari || isIOS) {
            setTimeout(function() {
                validateOTP(pId);
            }, 100);
        } else {
            validateOTP(pId);
        }
    }
}

