$(document).ready(function() {
    if(localStorage.getItem("userdata") && localStorage.getItem("userdata") != '' && localStorage.getItem("userdata") != null){

        $('body #payBtn').show();
        $('body #reservation_button').show();
    }else{
        $('body #loginBtnPay').show();
        $('body #reservation_button_check_login').show();
    }

    if (typeof(Storage) !== "undefined") {
        if (!localStorage.getItem('userdata') || localStorage.getItem('userdata') == '') {
            $('body #lgBtn').show();
            $('body #loginBtn').hide();
            $('.accountdvlogin').show();
            $('#welLgBTN').hide();
            $('.accountdv').hide();
            $('.walletShow').hide();
            $('.walletGuest').show();
            $('#showRaiseConcern').hide();
        } else {
            $('body #lgBtn').hide();
            $('body #loginBtn').show();
            $('.accountdvlogin').hide();
            var userData = JSON.parse(localStorage.getItem('userdata'));
            $('#welLgBTN').show();
            $('.accountdv').show();
            $('.walletShow').show();
            $('.walletGuest').hide();
            $('#showRaiseConcern').show();
            //  $('#welLgBTN').html('Welcome '+userData.name)

        }
    } else {
        $('#lgBtn').show();
        $('#showRaiseConcern').hide();
        $('.accountdvlogin').show();
    }

});




// When the user clicks on the button, scroll to the top of the document
function topFunction() {
    $('html,body').animate({
        scrollTop: 0
    }, 'slow');

}

// Scroll lock variables
let scrollY;

function openModalScroll() {
  scrollY = window.scrollY;
  document.documentElement.style.position = 'fixed';
  document.body.style.position = 'fixed';
  document.body.style.top = `-${scrollY}px`;
  document.body.style.width = '100%';
  document.body.style.overscrollBehavior = 'none';
  document.documentElement.style.overscrollBehavior = 'none';
}

function closeModalScroll() {
  document.body.style.position = '';
  document.documentElement.style.position = '';

  document.body.style.top = '';
  document.body.style.width = '';
  document.body.style.overscrollBehavior = '';
  document.documentElement.style.overscrollBehavior = '';
  window.scrollTo(0, scrollY);
}

function openLogin() {

    if(typeof webengage_tag == "function"){

        webengage.track("Link Clicked",{
            "Link Clicked" : "Login"
        });
    }

    if (pwa == 'paytm') {
        //   alert("paytm");
        tryCount = 0;
        paytmLogin();
    } else {
        $('#mobileNo').val('');
        $('#email_Id').val('');
        $('#validateOTP, #OTP').hide();
        $('#sendOTP').show();
        $('#resendOTP').hide();
        $(".submit_btn").addClass("disable");
        // Reset mobile login state: re-hide form, restore social buttons + "Login with OTP"
        if (window.innerWidth < 768) {
            var otpSec     = document.getElementById('otpFormSection');
            var sendOtpBtn = document.getElementById('sendOtpBtn');
            var otpBtn     = document.getElementById('loginWithOtpBtn');
            var changeLink  = document.getElementById('changeLoginMethodLink');
            if (otpSec)     otpSec.style.display     = 'none';
            if (sendOtpBtn) sendOtpBtn.style.display  = 'none';
            if (changeLink) changeLink.style.display  = 'none';
            if (otpBtn)     otpBtn.classList.remove('login-otp-hidden');
            _waCheckDone = false;
        }
        $('#loginModal').modal({
            backdrop: 'static',
            keyboard: false
        });
        if (typeof checkWhatsappBtnState === 'function') checkWhatsappBtnState();
        if (typeof initWhatsappLoginBtn === 'function' && typeof pId !== 'undefined') initWhatsappLoginBtn(pId);
        openModalScroll();
    }

}

function checkLogin(ecomm, cBID) {
    if (!localStorage.getItem('userdata') || localStorage.getItem('userdata') == '') {
        openLogin();
        return;
    } else {
        if (ecomm == 1) {
            var url = window.location.origin + "/checkout/" + cBID + "/1";
            window.location.href = url;
            return;
        }

    }

}

$('#mobileNo, #OTP').keypress(function(e) {
    return isNumber(e);
});



function sendOTP(pId) {
    var mobileNo = $('#mobileNo').val();
    if (mobileNo == '') {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Please enter Mobile number.");
        errormodalhide();
        return false;
    }

    if (mobileNo.length != 10) {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Mobile number should be 10 digits only.");
        errormodalhide();
        return false;
    }
    // Data consent (Terms & Privacy) - must be checked
    if ($('#data_consent').length && !$('#data_consent').is(':checked')) {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Please accept our Terms of Use and Privacy Policy to continue.");
        errormodalhide();
        return false;
    }
    var recaptchaResponse='';
    if(reCaptcha==1){
        recaptchaResponse = grecaptcha.getResponse();

        if (!recaptchaResponse) {
            $('#promonotapplied').modal('show');
            $('#promonotmsg').html("Please complete the reCAPTCHA.");
            errormodalhide();
            return;
        }
    }else{
        recaptchaResponse='';
    }
    
    // CI2 CAPTCHA validation (only if enabled)
    var ciCaptcha = '';
    if (ciCaptchaEnabled == 1) {
        ciCaptcha = $('#ci_captcha').val();
        
        // Check if CAPTCHA field exists
        if (!$('#ci_captcha').length) {
            $('#promonotapplied').modal('show');
            $('#promonotmsg').html("Security code field not found. Please refresh the page.");
            errormodalhide();
            return;
        }
        
        // Check if CAPTCHA image exists
        var captchaContainer = $('#ci-captcha-img');
        var captchaImg = captchaContainer.find('img');
        if (!captchaContainer.length || !captchaImg.length || !captchaImg.attr('src')) {
            $('#promonotapplied').modal('show');
            $('#promonotmsg').html("Security code image not loaded. Please refresh the page.");
            errormodalhide();
            return;
        }
        
        // Check if CAPTCHA input is empty
        if (!ciCaptcha || ciCaptcha.trim() === '') {
            $('#promonotapplied').modal('show');
            $('#promonotmsg').html("Please enter the security code.");
            errormodalhide();
            return;
        }
        
        // Validate CAPTCHA format (6 numeric characters)
        var captchaPattern = /^[0-9]{6}$/;
        if (!captchaPattern.test(ciCaptcha.trim())) {
            $('#promonotapplied').modal('show');
            $('#promonotmsg').html("Security code must be 6 numbers only.");
            errormodalhide();
            return;
        }
    }
    var url = origin + "/client/login/" + mobileNo + "/" + pId ;
    $.ajax({
        url: url,
        type: "POST",
        dataType: "json",
        xhrFields: {
            withCredentials: true
        },
        beforeSend: function(xhr) {
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        },
        data: {"recaptchaResponse": recaptchaResponse, "ci_captcha": ciCaptcha},
        success: function(result) {
            
                if(result.status == 0){
                    $('#promonotapplied').modal('show');
                    $('#promonotmsg').html(result.msg);
                    errormodalhide();
                    
                    // If it's a session-related error, refresh CAPTCHA
                    if(result.msg && (result.msg.includes('session expired') || result.msg.includes('refresh the page'))) {
                        refreshCaptcha();
                    }
                    
                    if(result['msg'] != 'Cannot Resend OTP Again.Please wait for sometime'){
                        return;
                    }
                } else {
                    // Success - clear attempt counter and refresh CAPTCHA (if enabled)
                    if (ciCaptchaEnabled == 1) {
                        localStorage.removeItem('captchaAttemptCount');
                        localStorage.removeItem('lastCaptchaAttempt');
                        refreshCaptcha();
                    }
                }
                readSMS = 1;
                startWebOTPListener();
                $('#enter_number').html(mobileNo);
                $('#verifyotp').modal({
                    backdrop: 'static',
                    keyboard: false
                });
                $('#verifyotp').modal('show');
                $('#loginModal').modal('hide');
                $('#validateOTP').show();
                setTimeout(function() {
                    $('#resendOTP').show()
                }, 30000);
                $('#sendOTP').hide();
                $('#OTP').show();
                $('#truecallerOr').hide();
                $('#truecallerBTN').hide();
                //$('#mobileNo').attr('readonly',true);
                if (result['status'] == 0){
                    $('#promonotapplied').modal('show');
                    $('#promonotmsg').html(result['msg']);
                    errormodalhide();
                }else{
                    /*$('#promoapplied').modal('show');
                    $('.promors').html(result['msg']);
                    setTimeout(function() {
                        $('#promoapplied').modal('hide')
                    }, 2500);*/
                }

                if (typeof gtag == "function") {

                    // console.log(tag);
                    gtag('event', 'send_otp');
                }
                if (typeof trackEvent === 'function') {
                    trackEvent("send_otp");
                }

                // $('#closeLoginModal').hide();
                //setTimeout(function() { $('#resendOTP').show(); }, 60000);
            
        },
        error: function(xhr, status, error) {
            // Handle HTTP error responses (400, 403, 429, etc.)
            var errorMessage = "An error occurred. Please try again.";
            
            // Try to parse error response if it's JSON
            if (xhr.responseText) {
                try {
                    var errorResponse = JSON.parse(xhr.responseText);
                    if (errorResponse.msg) {
                        errorMessage = errorResponse.msg;
                    }
                } catch (e) {
                    // If not JSON, use default message
                }
            }
            
            // Show error popup
            $('#promonotapplied').modal('show');
            $('#promonotmsg').html(errorMessage);
            errormodalhide();
            
            // If it's a session-related error, refresh CAPTCHA
            if (errorMessage.includes('session expired') || errorMessage.includes('refresh the page')) {
                refreshCaptcha();
            }
            
            // Refresh CAPTCHA on any error to prevent further issues
            if (ciCaptchaEnabled == 1) {
                refreshCaptcha();
            }
        }
    });
}

function sendEmailOTP(pId) {
    var email_Id = $('#email_Id').val();
    if (email_Id == '') {
        //   showAlert('');
        $('#errorMessageLogin').html('');
        $('#errorMessageLogin').html("Kindly Enter Valid Email Id");
        $("#danger-alert-login").fadeTo(2000, 500).slideUp(500, function() {
            $("#danger-alert-login").slideUp(500);
        });
        return false;
        //   return false;
    }
    var url = origin + "/email_login/login?email=" + email_Id + "&businessId=" + pId;
    $.ajax({
        url: url,
        type: "GET",
        dataType: "json",
        success: function(result) {
           if (result['status'] == 0) {
                //   showAlert();
                $('#verifyotp').modal('hide');
               $('#loginModal').modal('show');
                $('#promonotapplied').modal('show');
                $('#promonotmsg').html(result['msg']);
                errormodalhide();
                return false;
            } else {
                $('#email_enter').html(email_Id);
                $('#emailverifyotp').modal('show');
                $('#emailverifyotp').modal({
                    backdrop: 'static',
                    keyboard: false
                });
                $('#loginModal').modal('hide');
                cMappingId = result['contactIdMappingId'];
                $('#promoapplied').modal('show');
                $('.promors').html(result['msg']);
                setTimeout(function() {
                    $('#promoapplied').modal('hide')
                }, 2500);
            }
        }
    });
}

function resendOTP(pId) {
    var mobileNo = $('#mobileNo').val();
    if (mobileNo == '') {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Please enter Mobile number.");
        errormodalhide();
        return false;
    }

    if (mobileNo.length != 10) {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Mobile number should be 10 digits only.");
        errormodalhide();
        return false;
    }
    var mobileNo = $('#mobileNo').val();
    var url = origin + "/client/login/" + mobileNo + "/" + pId;
    $.ajax({
        url: url,
        type: "GET",
        dataType: "json",
        success: function(result) {
            if (result['status'] == 0) {
                $('#promonotapplied').modal('show');
                $('#promonotmsg').html(result['msg']);
                errormodalhide();
                return false;
            } else {

                $('#promoapplied').modal('show');
                $('.promors').html(result['msg']);
                setTimeout(function() {
                    $('#promoapplied').modal('hide')
                }, 2500);

                if (typeof trackEvent === 'function') {
                    trackEvent("resend_otp");
                }
            }
        }
    });

}

function errormodalhide() {
    setTimeout(function() {
        $('#promonotapplied').modal('hide')
    }, 2500);
}

var userClickedWalletGuest = false;

// Add a click event listener to the element with class "walletGuest"
$('.walletGuest').click(function() {
  
  userClickedWalletGuest = true;
  openLogin();
});





function validateOTP(pId) {
    // Wrap critical OTP code in try-catch to prevent fatal JS errors from stopping execution
    try {
        if (window.SMS) {
            document.addEventListener('onSMSArrive', function(e) {
                try {
                    var sms = e.data;
                    // Check if the SMS message contains an OTP code
                    var otpRegex = /(\d{6})/;
                    var match = sms.body.match(otpRegex);
                    if (match) {
                        var code = match[1];
                        $('#OTP').val(code).trigger('keyup');
                    }
                } catch (e) {
                    console.error('OTP SMS handler error:', e);
                }
            });
        }

        var mobileNo = $('#mobileNo').val();
        var OTP = '';
        
        // Try to get OTP from passcode wrapper inputs first (for multi-input OTP)
        $('.passcode-wrapper input').each(function() {
            OTP += $(this).val();
        });
        
        // If no OTP from passcode wrapper, try single input field
        if (OTP === '') {
            OTP = $('#OTP').val();
        }
    } catch (e) {
        console.error('OTP validation setup error:', e);
        releaseOTPValidationLock(false);
        $('#OTP').prop('disabled', false);
        return false;
    }
    if (mobileNo == '') {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Please enter Mobile number.");
        errormodalhide();
        return false;
    }

    if (mobileNo.length != 10) {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Mobile number should be 10 digits only.");
        errormodalhide()
        return false;
    }

    if (OTP == '') {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("Please enter OTP.");
        errormodalhide();
        return false;
    }

    if (OTP.length != 6) {
        $('#promonotapplied').modal('show');
        $('#promonotmsg').html("OTP should be 6 digits only.");
        errormodalhide()
        return false;
    }


    var ageConsentVal = (typeof ageConsentEnabled !== 'undefined' && ageConsentEnabled == 1) ? ($('input[name="age_consent"]:checked').val() || '0') : '0';
    var termsconsentVal = $('input[name="data_consent"]').val() || '0';
    var url = origin + "/client/validateNoByOTP";
    
    // Wrap AJAX call in try-catch for Safari compatibility
    // Enhanced for iOS 18.6.2 - handles CORS and Sentry interference
    try {
        // iOS 18.6.2 fix: Temporarily disable Sentry before making OTP request
        var sentryDisabled = false;
        var originalSentryMethods = {};
        
        if (window.Sentry) {
            try {
                // Disable Sentry's automatic request instrumentation
                if (window.Sentry.addBreadcrumb) {
                    originalSentryMethods.addBreadcrumb = window.Sentry.addBreadcrumb;
                    window.Sentry.addBreadcrumb = function() {
                        // Skip all breadcrumbs during OTP validation
                        return null;
                    };
                    sentryDisabled = true;
                }
                
                // Disable Sentry's captureException temporarily
                if (window.Sentry.captureException) {
                    originalSentryMethods.captureException = window.Sentry.captureException;
                    window.Sentry.captureException = function() {
                        // Skip exception capture during OTP validation
                        return null;
                    };
                }
            } catch (e) {
                console.warn('Failed to disable Sentry for OTP request:', e);
            }
        }
        var formData = new FormData();
        formData.append('mobile', mobileNo);
        formData.append('otp', OTP);
        formData.append('businessId', pId);
        formData.append('age_consent', Number(ageConsentVal ?? 0));
        formData.append('terms_consent', Number(termsconsentVal ?? 0));

        $.ajax({
            url: url,
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            dataType: 'json',
            success: function(result) {
                try {
                    // Reset the validation lock when API call completes
                    // Use keepCooldown=true on success, false on error to allow retry
                    var isSuccess = result['status'] != 0;
                    releaseOTPValidationLock(isSuccess);
                    
                    if (result['status'] == 0) {
                        // Show error modal
                        $('#promonotapplied').modal('show');
                        $('#promonotmsg').html(result['msg']);
                        $('#OTP').val('').prop('disabled', false); // Clear and re-enable OTP input field on invalid OTP
                        errormodalhide();
                        return false;
                    } else {
                        // ===== PRODUCTION-READY iOS Safari Login Success Fix =====
                        // Works for all iOS Safari versions (iPhone 13, 15, and all others)
                        // Ensures "Login Successful" modal always shows
                        
                        // Prepare success modal content immediately
                        $('.promors').html('Login Successful');
                        
                        // Function to show success modal - robust for all iOS versions
                        function showSuccessModal() {
                            try {
                        // Close location flow modal so it doesn't block cleanup on order/other pages
                        if (typeof closeLocationFlow === 'function') { closeLocationFlow(); }
                        $('#locationFlowModal').removeClass('show').css('display', 'none');

                        // Force remove any modal backdrop issues
                        $('.modal-backdrop').remove();
                        $('body').removeClass('modal-open');

                        // Reset body styles (critical for iOS Safari)
                        $('body').css({
                            'overflow': '',
                            'position': '',
                            'width': '',
                            'height': '',
                            'padding-right': ''
                        });
                        
                        // Ensure success modal exists and is ready
                        var $successModal = $('#promoapplied');
                        if (!$successModal.length) {
                            console.warn('Success modal not found');
                            return;
                        }
                        
                        // Force modal to front (works for all iOS versions)
                        $successModal.css({
                            'z-index': '10060',
                            'display': 'block'
                        });

                        // $addressModal.css({
                        //     'z-index': '10060',
                        //     'display': 'block'
                        // });
                        
                        // Remove any existing backdrop and create fresh one
                        $('.modal-backdrop').remove();
                        $('body').append('<div class="modal-backdrop fade show"></div>');
                        $('body').addClass('modal-open');
                        
                        // Show modal with proper animation
                        $successModal.addClass('show').css('display', 'block');
                        
                        // Ensure modal is visible
                        setTimeout(function() {
                            $successModal.focus();
                            // Trigger resize to ensure iOS Safari renders properly
                            window.dispatchEvent(new Event('resize'));
                        }, 50);
                        
                        // Auto-hide success modal after 2.5 seconds
                        setTimeout(function() {
                            $successModal.removeClass('show').css('display', 'none');
                            // Only keep modal-open if #locationFlowModal is open (home page saved addresses)
                            if (!$('#locationFlowModal').hasClass('show')) {
                                $('.modal-backdrop').remove();
                                $('body').removeClass('modal-open');
                            }
                        }, 2500);
                    } catch (e) {
                        console.error('Error showing success modal:', e);
                        // Fallback: Use Bootstrap modal method
                        $('#promoapplied').modal('show');
                        setTimeout(function() {
                            $('#promoapplied').modal('hide');
                        }, 2500);
                    }
                }
                
                // Hide OTP and login modals first, then show success
                var $otpModal = $('#verifyotp');
                var $loginModal = $('#loginModal');
                
                // For iOS devices, use more reliable modal sequencing
                if (isIOSSafari || isIOS) {
                    // Step 1: Hide both modals immediately
                    $otpModal.removeClass('show').css('display', 'none');
                    $loginModal.removeClass('show').css('display', 'none');
                    
                    // Step 2: Remove their backdrops
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open');
                    
                    // Step 3: Wait for DOM to update, then show success
                    // Use requestAnimationFrame for better iOS compatibility
                    requestAnimationFrame(function() {
                        setTimeout(function() {
                            showSuccessModal();
                            
                            // Fallback: If modal didn't show after 500ms, force show it
                            setTimeout(function() {
                                var $successModal = $('#promoapplied');
                                if (!$successModal.hasClass('show') || $successModal.css('display') === 'none') {
                                    console.warn('Success modal not visible, forcing show');
                                    $successModal.addClass('show').css({
                                        'display': 'block',
                                        'z-index': '10060'
                                    });
                                    if ($('.modal-backdrop').length === 0) {
                                        $('body').append('<div class="modal-backdrop fade show"></div>');
                                        $('body').addClass('modal-open');
                                    }
                                    setTimeout(function() {
                                        $successModal.removeClass('show').css('display', 'none');
                                        $('.modal-backdrop').remove();
                                        $('body').removeClass('modal-open');
                                    }, 2500);
                                }
                            }, 500);
                        }, 300);
                    });
                } else {
                    // Standard browsers: simpler approach
                    $otpModal.modal('hide');
                    $loginModal.modal('hide');
                    setTimeout(function() {
                        showSuccessModal();
                    }, 200);
                }
                if (typeof gtag == "function") {

                    // console.log(tag);
                    gtag('event', 'login_success');
                }

                if (typeof trackEvent === 'function') {
                    trackEvent("login_success");
                }


                if (typeof fbq == "function") {
                    fbq('track', 'CompleteRegistration');
                }

                

                

                readSMS = 0;
                var userdata = {
                        contactId: result['rows']['contactId'],
                        token: result['rows']['token'],
                        contactMappingId: result['rows']['contactMappingId'],
                        mobile: mobileNo,
                        name: result['rows']['name'],
                        email: result['rows']['email'],
                        dob: result['rows']['dob'],
                        gender: result['rows']['gender'],
                        anniversary: result['rows']['anniversary'],
                        married: result['rows']['married']
                    }
                    // userdata=;

                    if (typeof webengage_tag == "function") {

                        if(result['rows']['newUser'] == 1){

                            webengage.track("Customer Registered",{
                                "Phone Number" : mobileNo
                            });

                        }
                        webengage.user.login('+91'+ mobileNo);
                        webengage.user.setAttribute('we_phone', '+91'+ mobileNo);
                        if(userdata.email != null && userdata.email != '' && userdata.email != "null"){
                            webengage.user.setAttribute('we_email', userdata.email);
                        }
                        if(userdata.gender != null && userdata.gender != '' && userdata.gender != "null"){
                            var gender = userdata.gender.toLowerCase();
                            webengage.user.setAttribute('we_gender', gender);
                        }
                        if(userdata.dob != null && userdata.dob != '' && userdata.dob != "null"){
                            webengage.user.setAttribute('we_birth_date', userdata.dob);
                        }
                        if(userdata.anniversary != null && userdata.anniversary != '' && userdata.anniversary != "null"){
                            webengage.user.setAttribute('we_anniversary_date', userdata.anniversary);
                        }
                        if(userdata.name != null && userdata.name != '' && userdata.name != "null"){
                            webengage.user.setAttribute('we_first_name', userdata.name);
                        }

                        webengage.user.setAttribute('we_whatsapp_opt_in', true);
                    }

                localStorage.setItem('userdata', JSON.stringify(userdata));
                localStorage.setItem('token', userdata.token);
                
                // Hide modals properly (ensure they're closed for iOS Safari)
                $('#loginModal').removeClass('show').css('display', 'none');
                $('#verifyotp').removeClass('show').css('display', 'none');
                
                // Also use Bootstrap modal hide for compatibility
                $('#loginModal').modal('hide');
                $('#verifyotp').modal('hide');
                
                // Clean up form
                $('#mobileNo').val('');
                $('#validateOTP, #OTP').hide();
                $('#sendOTP').show();
                $('#resendOTP').hide();
                
                // Re-enable OTP input for next login
                $('#OTP').prop('disabled', false).val('');
                $('#menu-total').show();
                $('#loginBTN').hide();
                $('#cartBTN').show();
                $('#loginDIV').hide();
                $('#lgBtn').hide();
                $('.accountdvlogin').hide();
                $('#cartArea').show();
                $('#welLgBTN').show();
                $('#showRaiseConcern').show();
                $('.accountdv').show();
                $('.walletGuest').hide();
                $('.walletShow').show();
                $('body #loginBtnPay').hide();
                $('body #payBtn').show();
                $('body #reservation_button_check_login').hide();
                $('body #reservation_button').show();

                if(result['rows']['name'] == '' || result['rows']['name'] == null || result['rows']['name'] == "null"){
                    document.getElementById("namevalue").innerText = "User";
                }else{
                    document.getElementById("namevalue").innerText = result['rows']['name'];
                }
                
                document.getElementById("emailvalue").innerText = result['rows']['email'];



                if ((result['rows']['name'] == '' || result['rows']['name'] == null || result['rows']['name'] == 'user' || result['rows']['name'] == 'User') && !localStorage.getItem('userProfile')) {
                    if (result['rows']['email'] != null && result['rows']['email'] != 'null' && result['rows']['email'] != '') {
                        $('#uEmail').val(userdata['email']);
                    }
                    if(result['rows']['newUser'] == 0){
                        $(".referCodeInput").hide();
                    }else{
                        $(".referCodeInput").show();
                    }

                    // Hide any open location modals and clean up Bootstrap state to prevent overlap
                    $('#locationfetchmodal, #locationfetchoutletmodal, #theoLocationPopup, #savedAddressModal, #enteraddress, #nearbyoutlets').modal('hide');
                    setTimeout(function() {
                        $('.modal-backdrop').remove();
                        $('body').removeClass('modal-open fullmodalenabledhere');

                        $('#updateProfileModal_new').modal({
                            backdrop: 'static',
                            keyboard: false
                        });
                    }, 300);
                    // Do NOT set userProfile here - only set on successful form submit so modal reappears on refresh until submitted
                }

                // After successful login — update "Log In" buttons to "Saved Addresses"
                $('.login-or-saved-btn-text').text('Saved Addresses');

                // After successful login — open saved addresses modal (home + product pages)
                var currentPath = window.location.pathname;
                if (currentPath === '/' || currentPath === '' || currentPath.indexOf('/products/') > -1 || currentPath.indexOf('/product-detail/') > -1) {
                    setTimeout(function() {
                        if (typeof openLoginOrSavedAddresses === 'function') {
                            // Skip if updateProfile modal is visible (new/unnamed user) — will resume after profile is submitted or skipped
                            if ($('#updateProfileModal_new').hasClass('show') || $('#updateProfileModal_new').is(':visible')) {
                                window._pendingOpenSavedAddresses = true;
                                return;
                            }
                            openLoginOrSavedAddresses();
                        }
                    }, 500);
                }

                // iOS 18.6.2 fix: Add delay before navigation to ensure Sentry loads
                var navigationDelay = (isIOSSafari || isIOS) ? 500 : 0;
                
                if (userClickedWalletGuest) {
                    setTimeout(function() {
                        safePageReloadOrRedirect(origin + '/wallet');
                    }, navigationDelay);
                  }

                if (window.location.href.endsWith("wallet")) {
                    // Refresh the page safely (wait for Sentry scripts)
                    setTimeout(function() {
                        safePageReloadOrRedirect('reload');
                    }, navigationDelay);
                }

				 // Reload if URL contains both 'campaigns'
                if (window.location.pathname.endsWith("campaigns")) {
                    setTimeout(function() {
                        safePageReloadOrRedirect('reload');
                    }, navigationDelay);
                }

                // Reload if URL contains both 'campaigns'
                if (window.location.pathname.endsWith("refer-and-earn")) {
                    setTimeout(function() {
                        safePageReloadOrRedirect('reload');
                    }, navigationDelay);
                }

                // Reload if URL contains both 'campaigns'
                if (window.location.pathname.endsWith("memberships")) {
                    setTimeout(function() {
                        safePageReloadOrRedirect('reload');
                    }, navigationDelay);
                }
                // Handle URLs like /memberships/gold-dining-membership-1773394522
                if (/^\/memberships(\/|$)/.test(window.location.pathname)) {
                    setTimeout(function() {
                        safePageReloadOrRedirect('reload');
                    }, navigationDelay);
                }

                // Reload if URL contains both 'subscriptions' and 'package'
                if (window.location.href.endsWith("subscriptions") || window.location.href.endsWith("package")) {
                    setTimeout(function() {
                        safePageReloadOrRedirect('reload');
                    }, navigationDelay);
                }

                if (window.location.pathname.indexOf("nps") > -1) {
                    checkFormSubmitted();
                }

                        if(localStorage.getItem('userdata').length > 0){
                            $('#loginBtn').show();
                            $('#lgBtn').addClass('d-none');
                        }
                        if (((window.location.href.indexOf("reservation/") > -1) || (window.location.href.indexOf("order/") > -1)) && window.location.href.indexOf("online-order") == -1) {
                            add_to_cart('add', '');
                        }
                        if (window.location.href.indexOf("checkout") > -1) {
                            add_to_cart_login();
                            // iOS 18.6.2 fix: Add delay before navigation
                            var navigationDelay = (isIOSSafari || isIOS) ? 500 : 0;
                            setTimeout(function() {
                                safePageReloadOrRedirect('reload');
                            }, navigationDelay);
                        }
                        if (typeof gtag === "function") {
                            gtag('event', 'otp_validated', {
                                'event_category': 'otp_validated',
                                'event_label': 'OTP Validated',  // Label describing the button
                                'value': 1  // Optional: you can pass a value if needed
                            });
                        }
                    }  // Close else block
                } catch (e) {
                    console.error('OTP validation success handler error:', e);
                    releaseOTPValidationLock(false);
                    $('#OTP').prop('disabled', false);
                }
            },
            error: function(xhr, status, error) {
                try {
                    // Reset the validation lock if AJAX call fails
                    // Use keepCooldown=false to allow immediate retry
                    releaseOTPValidationLock(false);
                    
                    // Re-enable OTP input for retry
                    $('#OTP').prop('disabled', false);
                    
                    // iOS 18.6.2 fix: Handle CORS errors gracefully
                    var errorMessage = "An error occurred. Please try again.";
                    if (status === 'error' && xhr.status === 0) {
                        // CORS or network error
                        errorMessage = "Network error. Please check your connection and try again.";
                    } else if (xhr.status === 403 || xhr.status === 401) {
                        errorMessage = "Access denied. Please refresh the page and try again.";
                    } else if (xhr.status >= 500) {
                        errorMessage = "Server error. Please try again later.";
                    }
                    
                    // Show error modal
                    $('#promonotapplied').modal('show');
                    $('#promonotmsg').html(errorMessage);
                    errormodalhide();
                    
                    // Don't let Sentry log this error if Sentry itself is failing
                    // This prevents infinite error loops
                    if (window.Sentry && !window.sentryScriptState.failed) {
                        try {
                            window.Sentry.captureException(new Error('OTP validation failed: ' + status));
                        } catch (sentryError) {
                            // Ignore Sentry errors to prevent blocking
                            console.warn('Sentry logging failed, continuing:', sentryError);
                        }
                    }
                } catch (e) {
                    console.error('OTP validation error handler error:', e);
                    // Ensure UI is still usable even if error handling fails
                    $('#OTP').prop('disabled', false);
                    releaseOTPValidationLock(false);
                }
            }
        });
    } catch (e) {
        console.error('OTP validation AJAX setup error:', e);
        releaseOTPValidationLock(false);
        $('#OTP').prop('disabled', false);
    }
}

