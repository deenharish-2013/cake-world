});

// Monitor Sentry script loading errors - Enhanced for iOS 18.6.2
$(document).ready(function() {
    // Check if Sentry script exists in DOM
    var sentryScript = $('script[src*="sentry"]');
    if (sentryScript.length > 0) {
        window.sentryScriptState.loading = true;
        window.sentryScriptState.checkStartTime = Date.now();
        
        // Get the actual script element
        var scriptElement = sentryScript[0];
        
        // Enhanced error detection for iOS Safari
        scriptElement.addEventListener('error', function() {
            window.sentryScriptState.failed = true;
            window.sentryScriptState.loading = false;
            console.warn('Sentry script failed to load (error event)');
        }, { once: true });
        
        // Enhanced load detection for iOS Safari
        scriptElement.addEventListener('load', function() {
            window.sentryScriptState.loaded = true;
            window.sentryScriptState.loading = false;
            console.log('Sentry script loaded successfully');
        }, { once: true });
        
        // Fallback: Check if script already loaded (for iOS 18.6.2 edge cases)
        if (window.Sentry !== undefined) {
            window.sentryScriptState.loaded = true;
            window.sentryScriptState.loading = false;
        }
        
        // iOS 18.6.2 specific: Check script readyState periodically
        var readyStateCheck = setInterval(function() {
            if (scriptElement.readyState === 'complete' || scriptElement.readyState === 'loaded') {
                if (window.Sentry !== undefined) {
                    window.sentryScriptState.loaded = true;
                    window.sentryScriptState.loading = false;
                    clearInterval(readyStateCheck);
                }
            }
            
            // Stop checking after 10 seconds
            if (Date.now() - window.sentryScriptState.checkStartTime > 10000) {
                clearInterval(readyStateCheck);
            }
        }, 100);
    }
    
    // Also listen via jQuery for compatibility
    $(document).on('error', 'script[src*="sentry"], script[src*="bundle.min.js"]', function() {
        if (!window.sentryScriptState.failed) {
            window.sentryScriptState.failed = true;
            window.sentryScriptState.loading = false;
            console.warn('Sentry script failed to load (jQuery event)');
        }
    });
    
    $(document).on('load', 'script[src*="sentry"], script[src*="bundle.min.js"]', function() {
        if (!window.sentryScriptState.loaded) {
            window.sentryScriptState.loaded = true;
            window.sentryScriptState.loading = false;
        }
    });
    
    // Additional check: Verify Sentry is actually initialized (iOS 18.6.2)
    setTimeout(function() {
        if (window.Sentry && typeof window.Sentry.init === 'function') {
            window.sentryScriptState.loaded = true;
            window.sentryScriptState.loading = false;
        }
    }, 2000); // Check after 2 seconds
});

/**
 * Safe page reload or redirect function
 * Enhanced for iOS 18.6.2 - Ensures Sentry scripts have loaded before navigation
 * @param {string} action - 'reload' for reload, or URL string for redirect
 */
function safePageReloadOrRedirect(action) {
    try {
        var maxWaitTime = 8000; // Increased to 8 seconds for iOS 18.6.2
        var checkInterval = 50; // Check every 50ms for faster detection
        var elapsedTime = 0;
        var pollInterval = null;
        
        // Initialize state if not exists
        if (!window.sentryScriptState) {
            window.sentryScriptState = {
                loading: false,
                loaded: false,
                failed: false,
                checkStartTime: Date.now()
            };
        }
        
        var checkStartTime = window.sentryScriptState.checkStartTime || Date.now();
        elapsedTime = Date.now() - checkStartTime;
        
        /**
         * Comprehensive check for Sentry script status
         * Enhanced for iOS 18.6.2 detection
         */
        function checkSentryStatus() {
            // Method 1: Check if Sentry global object exists
            var sentryLoaded = window.Sentry !== undefined && window.Sentry !== null;
            
            // Method 2: Check script state tracking
            var sentryFailed = window.sentryScriptState && window.sentryScriptState.failed;
            var sentryLoadedState = window.sentryScriptState && window.sentryScriptState.loaded;
            
            // Method 3: Check performance API for Sentry script (iOS 18.6.2 compatible)
            var performanceEntries = [];
            try {
                if (window.performance && window.performance.getEntriesByType) {
                    performanceEntries = window.performance.getEntriesByType('resource') || [];
                }
            } catch (e) {
                // Performance API might not be available
            }
            
            var sentryResource = null;
            if (performanceEntries.length > 0) {
                sentryResource = performanceEntries.find(function(entry) {
                    if (!entry || !entry.name) return false;
                    var name = entry.name.toLowerCase();
                    return name.indexOf('sentry') > -1 || 
                           name.indexOf('bundle.min.js') > -1 ||
                           name.indexOf('b5c0d2a9fa1e04f55cc46c3bc48bc74e') > -1;
                });
            }
            
            // Method 4: Check if script element exists and is loaded (iOS 18.6.2 specific)
            var scriptElement = document.querySelector('script[src*="sentry"], script[src*="bundle.min.js"]');
            var scriptLoaded = false;
            if (scriptElement) {
                // Check if script has completed loading
                scriptLoaded = scriptElement.readyState === 'complete' || 
                              scriptElement.readyState === 'loaded' ||
                              scriptElement.readyState === '';
                
                // Also check if script is in DOM and not errored
                if (scriptElement.parentNode && !scriptElement.hasAttribute('data-error')) {
                    scriptLoaded = scriptLoaded || true;
                }
            }
            
            // Method 5: Check network state (iOS 18.6.2 fallback)
            var resourceLoaded = false;
            if (sentryResource) {
                // Check if resource has completed loading
                resourceLoaded = sentryResource.transferSize > 0 || 
                                sentryResource.decodedBodySize > 0 ||
                                sentryResource.duration > 0;
            }
            
            // Return true if ANY method indicates loaded or failed
            return {
                loaded: sentryLoaded || sentryLoadedState || scriptLoaded || resourceLoaded,
                failed: sentryFailed,
                canProceed: sentryLoaded || sentryFailed || sentryLoadedState || resourceLoaded || elapsedTime > maxWaitTime
            };
        }
        
        // Initial check
        var status = checkSentryStatus();
        
        if (status.canProceed) {
            // Script is loaded, failed, or timeout reached - safe to proceed
            if (action === 'reload') {
                location.reload();
            } else if (typeof action === 'string' && action.length > 0) {
                window.location.href = action;
            }
            return;
        }
        
        // Poll until Sentry loads, fails, or timeout
        pollInterval = setInterval(function() {
            elapsedTime += checkInterval;
            status = checkSentryStatus();
            
            if (status.canProceed || elapsedTime >= maxWaitTime) {
                if (pollInterval) {
                    clearInterval(pollInterval);
                    pollInterval = null;
                }
                
                // Log status for debugging iOS 18.6.2
                if (window.console && console.log) {
                    console.log('Sentry script status before navigation:', {
                        loaded: status.loaded,
                        failed: status.failed,
                        elapsedTime: elapsedTime,
                        sentryExists: window.Sentry !== undefined
                    });
                }
                
                if (action === 'reload') {
                    location.reload();
                } else if (typeof action === 'string' && action.length > 0) {
                    window.location.href = action;
                }
            }
        }, checkInterval);
        
        // Safety timeout - ensure we don't wait forever
        setTimeout(function() {
            if (pollInterval) {
                clearInterval(pollInterval);
                pollInterval = null;
            }
            
            // Proceed with navigation even if script status is unclear
            if (action === 'reload') {
                location.reload();
            } else if (typeof action === 'string' && action.length > 0) {
                window.location.href = action;
            }
        }, maxWaitTime + 1000); // Extra 1 second buffer
        
    } catch (e) {
        console.error('Error in safePageReloadOrRedirect:', e);
        // Fallback: proceed with navigation even if check fails
        if (action === 'reload') {
            location.reload();
        } else if (typeof action === 'string' && action.length > 0) {
            window.location.href = action;
        }
    }
}

(function () {
  let scrollY = 0;

  const observer = new MutationObserver(function (mutations) {
    if (!mutations.length) return;

    // Check the state BEFORE all mutations in this batch
    var firstOldValue = mutations[0].oldValue || '';
    var firstHadModal = firstOldValue.split(/\s+/).indexOf('modal-open') !== -1;

    // Check the state AFTER all mutations in this batch (current state)
    var lastHasModal = document.body.classList.contains('modal-open');

    if (!firstHadModal && lastHasModal) {
      // Net result: modal opened — save position and lock scroll
      scrollY = window.scrollY;
      document.documentElement.style.position = 'fixed';
      document.documentElement.style.top = `-${scrollY}px`;
      document.documentElement.style.width = '100%';
    } else if (firstHadModal && !lastHasModal) {
      // Net result: modal closed — unlock and restore position
      document.documentElement.style.position = '';
      document.documentElement.style.top = '';
      document.documentElement.style.width = '';
      window.scrollTo(0, scrollY);
    }
    // firstHadModal === lastHasModal: no net modal change — do nothing
  });

  observer.observe(document.body, {
    attributes: true,
    attributeFilter: ['class'],
    attributeOldValue: true
  });

})();

