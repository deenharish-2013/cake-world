}

function call(phoneNo) {
    window.open("tel:" + phoneNo);
}

// ─── WhatsApp Login ───────────────────────────────────────────────────────────
var _waCheckDone = false;

function initWhatsappLoginBtn(pId) {
    if (_waCheckDone) return;
    $.ajax({
        type: 'GET',
        url: origin + '/client/checkWhatsappLogin',
        data: { pId: pId }
    }).done(function(res) {
        _waCheckDone = true;
        try { res = JSON.parse(res); } catch(e) { return; }
        if (res.status == 1 && window.innerWidth < 768) {
            window._waLoginUrl = res.whatsapp_message;
            var waBTN = document.getElementById('whatsappLoginBTN');
            var orDiv = document.getElementById('truecallerOr');
            if (waBTN) {
                waBTN.style.display = 'flex';
                if (orDiv) orDiv.style.display = 'block';  // OR between social and "Login with OTP"
            }
        }
    });
}

// Mobile-first login modal: show method selection (social + OTP button), hide form
function setupMobileLoginModal() {
    if (window.innerWidth >= 768) return;
    var otpSection  = document.getElementById('otpFormSection');
    var otpBtn      = document.getElementById('loginWithOtpBtn');
    if (otpSection) otpSection.style.display = 'none';
    if (otpBtn)     otpBtn.style.display     = 'flex';
    // truecallerOr is managed by TrueCaller/WhatsApp JS — don't override here
}

// Called when user taps "Phone Number / Login with OTP" on mobile
function showOtpLoginForm() {
    var otpSection  = document.getElementById('otpFormSection');
    var sendOtpBtn  = document.getElementById('sendOtpBtn');
    var otpBtn      = document.getElementById('loginWithOtpBtn');
    var orDiv       = document.getElementById('truecallerOr');
    var tcBTN       = document.getElementById('truecallerBTN');
    var waBTN       = document.getElementById('whatsappLoginBTN');
    var changeLink  = document.getElementById('changeLoginMethodLink');
    if (otpSection) otpSection.style.display = 'block';
    if (sendOtpBtn) sendOtpBtn.style.display = 'block';
    if (changeLink) changeLink.style.display = 'block';
    // Add class to suppress the CSS !important show rule
    if (otpBtn)     otpBtn.classList.add('login-otp-hidden');
    if (orDiv)      orDiv.style.display      = 'none';
    if (tcBTN)      tcBTN.style.display      = 'none';
    if (waBTN)      waBTN.style.display      = 'none';
    // Focus phone input
    setTimeout(function() {
        var input = document.getElementById('mobileNo');
        if (input) input.focus();
    }, 100);
}

// Called when user taps "Change login method" — go back to method selection
function backToLoginMethods() {
    var otpSection  = document.getElementById('otpFormSection');
    var sendOtpBtn  = document.getElementById('sendOtpBtn');
    var otpBtn      = document.getElementById('loginWithOtpBtn');
    var orDiv       = document.getElementById('truecallerOr');
    var tcBTN       = document.getElementById('truecallerBTN');
    var waBTN       = document.getElementById('whatsappLoginBTN');
    var changeLink  = document.getElementById('changeLoginMethodLink');
    if (otpSection) otpSection.style.display = 'none';
    if (sendOtpBtn) sendOtpBtn.style.display = 'none';
    if (changeLink) changeLink.style.display = 'none';
    if (otpBtn)     otpBtn.classList.remove('login-otp-hidden');
    // Clear phone input
    var input = document.getElementById('mobileNo');
    if (input) input.value = '';
    $(".submit_btn").addClass("disable");
    // Re-show TrueCaller immediately (Android)
    var isAndroid = /android/i.test(navigator.userAgent);
    if (tcBTN && isAndroid) {
        tcBTN.style.display = 'flex';
        if (orDiv) orDiv.style.display = 'block';
    }
    // Re-show WhatsApp instantly if already confirmed enabled (no AJAX needed)
    if (window._waLoginUrl && waBTN) {
        waBTN.style.display = 'flex';
        if (orDiv) orDiv.style.display = 'block';
        if (typeof checkWhatsappBtnState === 'function') checkWhatsappBtnState();
    } else {
        // First time — need AJAX
        _waCheckDone = false;
        if (typeof initWhatsappLoginBtn === 'function' && typeof pId !== 'undefined') initWhatsappLoginBtn(pId);
    }
}

function checkSocialBtnState() {
    var dataConsentOk = !$('#data_consent').length || $('#data_consent').is(':checked');
    var ageConsentOk  = (typeof ageConsentEnabled === 'undefined' || ageConsentEnabled != 1) ||
                        $('input[name="age_consent"]:checked').length > 0;
    var allOk = dataConsentOk && ageConsentOk;

    // WhatsApp button
    var $wa = $('#whatsappLoginBTN');
    if (allOk) {
        $wa.css({ 'background': '#25D366', 'color': '#fff', 'border': '1px solid #25D366', 'cursor': 'pointer', 'pointer-events': 'auto' });
        $wa.find('#waBtnIcon svg').attr('fill', '#fff');
    } else {
        $wa.css({ 'background': '#b0b4c0', 'color': '#fff', 'border': '1px solid #b0b4c0', 'cursor': 'not-allowed', 'pointer-events': 'auto' });
        $wa.find('#waBtnIcon svg').attr('fill', '#fff');
    }

}
// keep old name as alias so any existing callers still work
function checkWhatsappBtnState() { checkSocialBtnState(); }
$(document).on('change', '#data_consent, input[name="age_consent"]', function() {
    checkSocialBtnState();
});

function highlightConsentCheckbox() {
    if (!document.getElementById('wa-consent-shake-style')) {
        var st = document.createElement('style');
        st.id = 'wa-consent-shake-style';
        st.textContent = '@keyframes wa-consent-shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}40%{transform:translateX(6px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}} .wa-consent-highlight{animation:wa-consent-shake 0.4s ease;}';
        document.head.appendChild(st);
    }
    var targets = [];
    if ($('#data_consent').length && !$('#data_consent').is(':checked')) targets.push($('#checkboxwrapper2'));
    if ((typeof ageConsentEnabled !== 'undefined' && ageConsentEnabled == 1) && !$('input[name="age_consent"]').is(':checked')) targets.push($('#checkboxwrapper'));
    $.each(targets, function(_, $el) {
        $el.removeClass('wa-consent-highlight');
        void $el[0].offsetWidth; // reflow to restart animation
        $el.addClass('wa-consent-highlight');
        setTimeout(function() { $el.removeClass('wa-consent-highlight'); }, 1500);
    });
}

function whatsappLogin(pId) {
    // If consents not satisfied, highlight the checkbox and bail
    var dataConsentOk = !$('#data_consent').length || $('#data_consent').is(':checked');
    var ageConsentOk  = (typeof ageConsentEnabled === 'undefined' || ageConsentEnabled != 1) ||
                        $('input[name="age_consent"]:checked').length > 0;
    if (!dataConsentOk || !ageConsentOk) {
        highlightConsentCheckbox();
        return;
    }

    var $btn      = $('#whatsappLoginBTN');
    var $btnText  = $('#waBtnText');
    var $btnIcon  = $('#waBtnIcon');
    var spinnerHtml = '<svg width="18" height="18" viewBox="0 0 38 38" xmlns="http://www.w3.org/2000/svg" stroke="#fff" style="vertical-align:middle;animation:wa-spin 0.8s linear infinite"><g fill="none" fill-rule="evenodd"><g transform="translate(1 1)" stroke-width="3"><circle stroke-opacity=".4" cx="18" cy="18" r="18"/><path d="M36 18c0-9.94-8.06-18-18-18"/></g></g></svg>';
    if (!document.getElementById('wa-spin-style')) {
        var st = document.createElement('style');
        st.id = 'wa-spin-style';
        st.textContent = '@keyframes wa-spin { 100% { transform: rotate(360deg); } }';
        document.head.appendChild(st);
    }

    function showLoader() {
        $btn.prop('disabled', true).css({ 'opacity': '0.8', 'pointer-events': 'none' });
        if ($btnText.length) $btnText.text('Redirecting...');
        if ($btnIcon.length) $btnIcon.html(spinnerHtml);
    }
    function hideLoader() {
        $btn.prop('disabled', false).css({ 'opacity': '1', 'pointer-events': 'auto' });
        if ($btnText.length) $btnText.text('WhatsApp');
        if ($btnIcon.length) $btnIcon.html('<svg viewBox="0 0 24 24" fill="#fff" xmlns="http://www.w3.org/2000/svg" style="height:20px;vertical-align:middle;margin-right:6px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>');
    }

    if (window._waLoginUrl) {
        localStorage.setItem('wa_redirect_url', window.location.href);
        window.open(window._waLoginUrl, '_blank');
    } else {
        showLoader();
        $.ajax({
            type: 'GET',
            url: origin + '/client/checkWhatsappLogin',
            data: { pId: pId }
        }).done(function(res) {
            hideLoader();
            try { res = JSON.parse(res); } catch(e) {
                $('#promonotapplied').modal('show');
                $('#promonotmsg').html('WhatsApp login is not available.');
                errormodalhide();
                return;
            }
            if (res.status == 1) {
                window._waLoginUrl = res.whatsapp_message;
                localStorage.setItem('wa_redirect_url', window.location.href);
                window.open(res.whatsapp_message, '_blank');
            } else {
                $('#promonotapplied').modal('show');
                $('#promonotmsg').html(res.msg || 'WhatsApp login is not enabled. Proceed with regular login methods.');
                errormodalhide();
            }
        }).fail(function() {
            hideLoader();
            $('#promonotapplied').modal('show');
            $('#promonotmsg').html('Unable to connect. Please try again.');
            errormodalhide();
        });
    }
}
// ─────────────────────────────────────────────────────────────────────────────

function truecallerLogin(pId) {
    let requestNonce = pId + '-' + Math.floor(Math.random() * 100000000);; // random number of length 8 to 64 characters
    window.location = "truecallersdk://truesdk/web_verify?" +
        "type=btmsheet&" +
        "requestNonce=" + requestNonce +
        "&partnerKey=" + truecaller_key +
        "&partnerName=" + encodeURI(businessName) +
        "&lang=en&loginPrefix=placeorder&loginSuffix=login&ctaPrefix=proceedwith&ctaColor=%230099ff&ctaTextColor=%23ffffff&btnShape=Round&skipOption=Later";

    setTimeout(function() {

        if (document.hasFocus()) {
            alert("Oops! Truecaller Not Installed");

        } else {
            truecallerRequestId = requestNonce;
            $('#truecallerModal').modal('show');
            getTruecallerLoginStatus();
        }
    }, 600);
}

