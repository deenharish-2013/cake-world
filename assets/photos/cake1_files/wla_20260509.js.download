                                        <p class="mb-0 level-three-para"> ${dataDetail['pax'] > 1 ? dataDetail['pax'] + ' Guests' : dataDetail['pax'] + ' Guest'}</p> <p class="d-inline-block ml-2 level-three-para mb-0">| ${statusDiv}</p> 
