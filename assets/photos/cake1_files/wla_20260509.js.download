/*scroll to top*/
$(window).scroll(function() {
    if ($(this).scrollTop() >= 200) { // If page is scrolled more than 50px
        $('#return-to-top').fadeIn(200); // Fade in the arrow
    } else {
        $('#return-to-top').fadeOut(200); // Else fade out the arrow
    }
});
$('#return-to-top').click(function() { // When arrow is clicked
    $('body,html').animate({
        scrollTop: 0 // Scroll to top of body
    }, 500);
});
/*scroll to top*/

$(document).ready(function() {

    const $modal = $('#updateProfileModal_new');
    const $fullName = $('#FullName');

    // Show profile modal on page load if user is logged in but profile not yet submitted (mandatory until submit)
    try {
        var ud = localStorage.getItem('userdata');
        if (ud && ud !== '') {
            var userData = JSON.parse(ud);
            var name = (userData['name'] == null || userData['name'] === '') ? '' : String(userData['name']).trim();
            var needsProfile = (name === '' || name === 'user' || name === 'User');
            if (needsProfile && !localStorage.getItem('userProfile')) {
                if (userData['email']) {
                    $('#EmailAddress').val(userData['email'] || '');
                }
                // Hide any open location modals and clean up Bootstrap state to prevent overlap
                $('#locationfetchmodal, #locationfetchoutletmodal, #theoLocationPopup, #savedAddressModal, #enteraddress, #nearbyoutlets').modal('hide');
                setTimeout(function() {
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open fullmodalenabledhere');
                    $modal.modal({ backdrop: 'static', keyboard: false });
                }, 300);
            }
        }
    } catch (e) {}

    // Prevent Bootstrap modal hide if mandatory field empty
    $modal.on('hide.bs.modal', function(e) {
        if ($modal.hasClass('mandatoryinfo')) {
            const fullName = $fullName.val().trim();

            if (fullName === '') {
                e.preventDefault(); // Block close
                e.stopImmediatePropagation();
                $fullName.addClass('is-invalid');
                return false;
            }
        }
    });

    // Remove red border when user types
    $fullName.on('input', function() {
        $(this).removeClass('is-invalid');
    });

    // Prevent submit if field empty
    $('.submit_btn').on('click', function(e) {
        const fullName = $fullName.val().trim();

        if (fullName === '') {
            e.preventDefault();
            $fullName.addClass('is-invalid');
            return false;
        } else {
            $fullName.removeClass('is-invalid');
            // proceed with your submit logic
            // Example: uProfileUpdate(58222);
        }
    });
    

    // --- Referral login UI logic Starts here--- //
    var isLoggedIn = false;
    try {
        var userData = localStorage.getItem('userdata');
        if (userData && userData !== '' && userData !== 'null') {
            isLoggedIn = true;
        }
    } catch (e) {}

    // Show/hide Refer Now button and promo-code-section
    if (isLoggedIn) {
        // Disable Refer Now button and update text
        var $referBtn = $("#orderLoginBtn").closest('button');
        $referBtn.prop('disabled', true);
        $referBtn.addClass('disabled');
        $referBtn.find('#orderLoginBtn').text('Referring Now');
        // Show promo-code-section
        $('.promo-code-section').show();
        $('.referral-section').removeClass('without-referral--img');
        $('.invite-section').removeClass('without-referral');
        $('.referral-activity-section').show();

        userData = JSON.parse(userData);
        var contactId = userData['contactId'];
        var contactMappingId = userData['contactMappingId'];
        if (typeof contactId !== "undefined" && contactId) {
            var url = window.location.origin + "/wlp/getReferralData";
            $.ajax({
                url: url,
                type: 'POST',
                data: {
                    contactMappingId: contactMappingId,
                    contactId: contactId
                },
                success: function(response) {
                    try {
                        var resp = typeof response === 'string' ? JSON.parse(response) : response;
                        if (resp.status === 1 && resp.referralCode) {
                            $(".referralCodeVal").text(resp.referralCode);
                            $(".total-referrals").text(resp.mis.total_referrals);
                            $(".order-not-placed").text(resp.mis.no_order);
                            $(".pending_orders").text(resp.mis.pending);
                            $(".order-not-delivered").text(resp.mis.order_placed_not_delivered);
                            $(".completed_orders").text(resp.mis.completed);
                            const referralValue = Number(resp.referral_rules.referral_value) || 0;
                            const refereeValue = Number(resp.referral_rules.referee_value) || 0;
                            const referralValueFormatted = new Intl.NumberFormat('en-IN', {
                                style: 'currency',
                                currency: 'INR'
                            }).format(referralValue);
                            $(".referral_rewards").html(referralValueFormatted);

                            const refereeValueFormatted = new Intl.NumberFormat('en-IN', {
                                style: 'currency',
                                currency: 'INR'
                            }).format(refereeValue);
                            $(".referre_rewards").html(refereeValueFormatted);

                            const formatted = new Intl.NumberFormat('en-IN', {
                                style: 'currency',
                                currency: 'INR'
                            }).format(Number(resp.mis.rewards_amount) || 0);
                            $(".total_earning").html(formatted);

                            // Render referral table rows from resp.queue
                            var tbody = document.getElementById('referralTableBody');
                            if (tbody) {
                                tbody.innerHTML = '';
                                // Handle queue as array or object
                                if (resp.queue && typeof resp.queue === 'object' && Object.keys(resp.queue).length > 0) {
                                    var referrals = [];
                                    Object.keys(resp.queue).forEach(function(key) {
                                        if (!isNaN(key)) {
                                            referrals.push(resp.queue[key]);
                                        }
                                    });
                                    referrals.forEach(function(ref) {
                                        var srNo = referrals.indexOf(ref) + 1;
                                        var refree_name = ref.contactName || '';
                                        var status = '';
                                        if (ref.processed === '' || ref.processed === null || typeof ref.processed === 'undefined') {
                                            status = 'Order Not Placed';
                                        } else if (ref.processed === '1' || ref.processed === 1) {
                                            status = 'Completed';
                                        } else {
                                            status = 'Pending';
                                        }
                                        var statusClass = 'warning';
                                        if (status === 'Completed') {
                                            statusClass = 'success';
                                        } else if (status === 'Order Not Placed') {
                                            statusClass = 'danger';
                                        }
                                        var orderValueFormatted = '-';
                                        if (!(ref.processed === '' || ref.processed === null || typeof ref.processed === 'undefined')) {
                                            orderValueFormatted = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR' }).format(ref.order_value || ref.total || 0);
                                        }
                                        var rewardsFormatted = '-';
                                        if (!(ref.processed === '' || ref.processed === null || typeof ref.processed === 'undefined')) {
                                            rewardsFormatted = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR' }).format(ref.rewards || 0);
                                        }
                                        var row = `<tr>
                                            <td>${srNo}</td>
                                            <td>${refree_name}</td>
                                            <td><span class="badge badge-soft-${statusClass} px-3 py-1">${status}</span></td>
                                            <td>
                                                ${
                                                    ref.date || ref.insertedAt
                                                    ? new Date(ref.date || ref.insertedAt).toLocaleString('en-IN', {
                                                        day: '2-digit',
                                                        month: 'short',
                                                        year: 'numeric',
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                        })
                                                    : '-'
                                                }
                                            </td>
                                            <td>${orderValueFormatted}</td>
                                            <td>${rewardsFormatted}</td>
                                        </tr>`;
                                        tbody.innerHTML += row;
                                    });
                                    $(".view-all-referrals").show();
                                } else {
                                    tbody.innerHTML = '<tr><td colspan="6" class="text-center">No referrals found.</td></tr>';
                                    $(".view-all-referrals").hide();
                                }
                            }
                        }
                    } catch (e) {
                        console.error('Referral code response error:', e);
                    }
                }
            });
        }

    } else {
        // Enable Refer Now button and restore text
        var $referBtn = $("#orderLoginBtn").closest('button');
        $referBtn.prop('disabled', false);
        $referBtn.removeClass('disabled');
        $referBtn.find('#orderLoginBtn').text('Refer Now');
        // Hide promo-code-section
        $('.promo-code-section').hide();
        $('.invite-section').addClass("without-referral");
        $('.referral-section').addClass('without-referral--img');
        $('.referral-activity-section').hide();

    }
});
function copyReferralCode() {
    var referralCode = $(".referralCodeVal").text();

    if (navigator && navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        navigator.clipboard.writeText(referralCode).then(function() {
            
            // Set copied text inside modal input
            $("#copytxt").val(referralCode);

            // Open modal
            $("#copyCode").modal("show");

            // Auto close after 0.8 seconds (800ms)
            setTimeout(function() {
                $("#copyCode").modal("hide");
            }, 1200);

        }, function(err) {
            console.log('Could not copy referral code.');
        });
    } else {
        console.log('Clipboard API not supported.');
    }
}
document.addEventListener('DOMContentLoaded', function() {
    // Get the referral code from the URL
    const params = new URLSearchParams(window.location.search);
    const referCode = params.get('refer');
    if (referCode) {
        // Set the value in the referral_code input field
        document.getElementById('referral_code').value = referCode;
    }
});

// JS for sharing referral code via WhatsApp, SMS, QR Code

function getReferralCode() {
    // Get referral code from DOM
    var codeElem = document.querySelector('.referralCodeVal');
    return codeElem ? codeElem.textContent.trim() : '';
}

function shareReferral(type) {
    var referralCode = getReferralCode();
    var shareMsg = 'Join me and earn rewards! Use my referral code: ' + referralCode + '.';
    var shareUrl = window.location.origin + '?refer=' + encodeURIComponent(referralCode);
    if (!referralCode) {
        alert('Referral code not found!');
        return;
    }
    if (type === 'whatsapp') {
        var whatsappUrl = 'https://wa.me/?text=' + encodeURIComponent(shareMsg + '\n' + shareUrl);
        window.open(whatsappUrl, '_blank');
    } else if (type === 'sms') {
        var smsUrl = 'sms:?body=' + encodeURIComponent(shareMsg + '\n' + shareUrl);
        window.open(smsUrl, '_self');
    } else if (type === 'qr') {
        // Show QR code modal
        showReferralQRCode(referralCode, shareUrl);
    }
}

function showReferralQRCode(referralCode, shareUrl) {
    // Remove any existing modal
    var modalId = 'referralQrModal';
    var oldModal = document.getElementById(modalId);
    if (oldModal) oldModal.remove();

    // Create modal HTML
    var modal = document.createElement('div');
    modal.id = modalId;
    modal.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:9999;';
    modal.innerHTML = '<div style="background:#fff;padding:32px;border-radius:12px;text-align:center;position:relative;max-width:320px;">' +
        '<h4>Scan QR to Join</h4>' +
        '<div id="qrCodeBox"></div>' +
        '<p style="margin-top:16px;">Referral Code: <b>' + referralCode + '</b></p>' +
        '<button id="closeQrModalBtn" style="margin-top:16px;" class="btn btn-danger">Close</button>' +
        '</div>';
    document.body.appendChild(modal);
    document.getElementById('closeQrModalBtn').onclick = function() {
        modal.remove();
    };

    // Helper to render QR code
    function renderQRCodeSimple() {
        var qrBox = document.getElementById('qrCodeBox');
        if (qrBox) {
            qrBox.innerHTML = '';
            var qrData = shareUrl;
            if (window.QRCode) {
                new QRCode(qrBox, {text: qrData, width: 180, height: 180});
            } else {
                qrBox.innerHTML = '<div style="color:red;">QR code library not loaded.</div>';
            }
        }
    }
    // Only load QRCode.js if not present and not already loading
    if (!window.QRCode) {
        if (!window._qrCodeScriptLoading) {
            window._qrCodeScriptLoading = true;
            var script = document.createElement('script');
            script.src = 'https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';
            script.onload = function() {
                window._qrCodeScriptLoading = false;
                renderQRCodeSimple();
            };
            script.onerror = function() {
                window._qrCodeScriptLoading = false;
                var qrBox = document.getElementById('qrCodeBox');
                if (qrBox) qrBox.innerHTML = '<div style="color:red;">Failed to load QR code library.</div>';
            };
            document.body.appendChild(script);
        } else {
            // If already loading, poll until loaded then render
            var pollInterval = setInterval(function() {
                if (window.QRCode) {
                    clearInterval(pollInterval);
                    renderQRCodeSimple();
                }
            }, 100);
        }
    } else {
        renderQRCodeSimple();
    }
}