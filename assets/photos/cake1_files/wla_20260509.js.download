var readSMS = 0;
var pwa = 'web';
var tryCount = 0;
var uagent = navigator.userAgent;
var domain = window.location.hostname;
var testing = 0;
var truecallerRequestId = '';
var pollingCount = 0;
var cMappingId;
var pId;
var origin = window.location.origin;

// ===== GLOBAL ERROR HANDLER FOR SAFARI OTP AUTOFILL =====
// Catches fatal JS errors that can stop execution (critical for bundle.min.js errors)
// Enhanced for iOS 18.6.2 - prevents Sentry envelope errors from blocking OTP validation
window.addEventListener('error', function(e) {
    // Ignore Sentry-related errors to prevent them from blocking OTP validation
    if (e.filename && (
        e.filename.indexOf('sentry') > -1 || 
        e.filename.indexOf('bundle.min.js') > -1 ||
        e.filename.indexOf('b5c0d2a9fa1e04f55cc46c3bc48bc74e') > -1 ||
        (e.message && (
            e.message.indexOf('envelope') > -1 ||
            e.message.indexOf('sentry') > -1 ||
            e.message.indexOf('access control checks') > -1 && e.message.indexOf('validateMobileByOTP') > -1
        ))
    )) {
        console.warn('Sentry/envelope error ignored to prevent blocking:', e.message);
        return true; // Prevent Sentry errors from blocking execution
    }
    
    // Log other errors but don't let them stop OTP validation flow
    console.error('Global JS error:', e.message, e.filename, e.lineno);
    return true; // Prevents default error handling
});

window.addEventListener('unhandledrejection', function(e) {
    console.error('Unhandled Promise rejection:', e.reason);
    
    // Ignore Sentry-related promise rejections
    if (e.reason && (
        String(e.reason).indexOf('sentry') > -1 ||
        String(e.reason).indexOf('envelope') > -1
    )) {
        console.warn('Sentry promise rejection ignored:', e.reason);
        e.preventDefault();
        return;
    }
    
    // Prevent unhandled rejections from crashing the app
    e.preventDefault();
});

// ===== SENTRY ERROR HANDLING WRAPPER =====
// Prevents Sentry errors from interfering with OTP validation on iOS 18.6.2
// Critical: Makes Sentry failures non-blocking
(function() {
    // Wait for Sentry to load, then wrap it
    function wrapSentryWhenReady() {
        if (typeof window.Sentry === 'undefined' || !window.Sentry) {
            // Retry after 500ms if Sentry not loaded yet
            setTimeout(wrapSentryWhenReady, 500);
            return;
        }
        
        try {
            // Wrap Sentry's captureException to handle failures gracefully
            if (window.Sentry.captureException) {
                var originalCaptureException = window.Sentry.captureException.bind(window.Sentry);
                window.Sentry.captureException = function(error, hint) {
                    try {
                        // Don't log OTP validation requests to prevent interference
                        if (error && (
                            String(error).indexOf('validateMobileByOTP') > -1 ||
                            String(error).indexOf('OTP') > -1 ||
                            (hint && hint.request && hint.request.url && hint.request.url.indexOf('validateMobileByOTP') > -1)
                        )) {
                            console.warn('Skipping Sentry log for OTP validation to prevent interference');
                            return null;
                        }
                        return originalCaptureException(error, hint);
                    } catch (e) {
                        console.warn('Sentry captureException failed, continuing:', e);
                        return null; // Don't throw, just log
                    }
                };
            }
            
            // Wrap Sentry's captureMessage to handle failures gracefully
            if (window.Sentry.captureMessage) {
                var originalCaptureMessage = window.Sentry.captureMessage.bind(window.Sentry);
                window.Sentry.captureMessage = function(message, level, hint) {
                    try {
                        // Don't log OTP-related messages to prevent interference
                        if (message && (
                            String(message).indexOf('validateMobileByOTP') > -1 ||
                            String(message).indexOf('OTP') > -1
                        )) {
                            console.warn('Skipping Sentry log for OTP message to prevent interference');
                            return null;
                        }
                        return originalCaptureMessage(message, level, hint);
                    } catch (e) {
                        console.warn('Sentry captureMessage failed, continuing:', e);
                        return null; // Don't throw, just log
                    }
                };
            }
            
            // Disable Sentry's automatic request instrumentation for OTP endpoints
            // This prevents Sentry from intercepting OTP validation requests
            if (window.Sentry.getCurrentHub) {
                try {
                    var hub = window.Sentry.getCurrentHub();
                    if (hub && hub.getClient) {
                        var client = hub.getClient();
                        if (client && client.getOptions) {
                            var options = client.getOptions();
                            // Configure Sentry to ignore OTP validation endpoints
                            if (options && !options.ignoreErrors) {
                                options.ignoreErrors = [];
                            }
                            if (options && options.ignoreErrors) {
                                options.ignoreErrors.push(/validateMobileByOTP/);
                                options.ignoreErrors.push(/OTP/);
                            }
                        }
                    }
                } catch (e) {
                    console.warn('Sentry configuration update failed:', e);
                }
            }
            
            // Configure Sentry to ignore OTP validation endpoints and prevent interference
            // This prevents Sentry from intercepting OTP validation requests
            try {
                // Method 1: Configure ignoreUrls if Sentry supports it
                if (window.Sentry.getCurrentHub) {
                    var hub = window.Sentry.getCurrentHub();
                    if (hub && hub.getClient) {
                        var client = hub.getClient();
                        if (client && client.getOptions) {
                            var options = client.getOptions();
                            
                            // Add OTP endpoints to ignore list
                            if (!options.ignoreUrls) {
                                options.ignoreUrls = [];
                            }
                            if (Array.isArray(options.ignoreUrls)) {
                                options.ignoreUrls.push(/validateMobileByOTP/);
                                options.ignoreUrls.push(/\/client\/validateMobileByOTP/);
                            }
                            
                            // Disable breadcrumbs for OTP requests
                            if (options.beforeBreadcrumb) {
                                var originalBeforeBreadcrumb = options.beforeBreadcrumb;
                                options.beforeBreadcrumb = function(breadcrumb, hint) {
                                    if (breadcrumb && breadcrumb.data && breadcrumb.data.url) {
                                        if (breadcrumb.data.url.indexOf('validateMobileByOTP') > -1) {
                                            return null; // Ignore OTP validation breadcrumbs
                                        }
                                    }
                                    return originalBeforeBreadcrumb ? originalBeforeBreadcrumb(breadcrumb, hint) : breadcrumb;
                                };
                            } else {
                                options.beforeBreadcrumb = function(breadcrumb, hint) {
                                    if (breadcrumb && breadcrumb.data && breadcrumb.data.url) {
                                        if (breadcrumb.data.url.indexOf('validateMobileByOTP') > -1) {
                                            return null; // Ignore OTP validation breadcrumbs
                                        }
                                    }
                                    return breadcrumb;
                                };
                            }
                        }
                    }
                }
                
                // Method 2: Temporarily disable Sentry when making OTP requests
                // This is handled in the AJAX beforeSend callback
            } catch (e) {
                console.warn('Sentry ignoreUrls configuration failed:', e);
            }
            
        } catch (e) {
            console.warn('Sentry error handling wrapper failed:', e);
        }
    }
    
    // Start wrapping when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', wrapSentryWhenReady);
    } else {
        wrapSentryWhenReady();
    }
    
    // Also try after a delay in case Sentry loads later
    setTimeout(wrapSentryWhenReady, 1000);
})();

// ===== SENTRY SCRIPT STATE TRACKING =====
// Track Sentry script loading state globally (prevents bundle.min.js loading errors)
// Enhanced for iOS 18.6.2 compatibility
window.sentryScriptState = {
    loading: false,
    loaded: false,
    failed: false,
    checkStartTime: null,
    retryCount: 0,
    maxRetries: 3
};

// Initialize check start time immediately
window.sentryScriptState.checkStartTime = Date.now();

// ===== iOS DETECTION (Early definition for use in validateOTP) =====
// Comprehensive iOS detection for all versions and devices (including iOS 18.6.2)
var isIOSSafari = (function() {
    var ua = navigator.userAgent || '';
    // Detect iOS devices (iPhone, iPad, iPod) - works for all iOS versions
    var iOS = /iPad|iPhone|iPod/.test(ua) && !window.MSStream;
    // Detect Safari browser (exclude Chrome, Firefox, Opera on iOS)
    var safari = /Safari/.test(ua) && !/CriOS|FxiOS|OPiOS|mercury|EdgiOS/.test(ua);
    return iOS && safari;
})();

// Detect any iOS browser (iPhone, iPad, iPod) - comprehensive detection
var isIOS = (function() {
    var ua = navigator.userAgent || '';
    // Check for iOS devices
    if (/iPad|iPhone|iPod/.test(ua) && !window.MSStream) {
        return true;
    }
    // Fallback: Check for iOS in platform
    if (navigator.platform && /iPad|iPhone|iPod/.test(navigator.platform)) {
        return true;
    }
    // Additional check for iOS 13+ which might not have iPad in UA
    if (navigator.maxTouchPoints && navigator.maxTouchPoints > 2 && /MacIntel/.test(navigator.platform)) {
        return true;
    }
    return false;
})();

// All iOS Safari: use button-only OTP + fetch() for reliable login across all versions (including 18.6.x autofill)
var isIOSSafariForOTP = (function() {
    return !!(isIOSSafari || isIOS);
})();


// === WebOTP Autofill Handler (Chrome only — Safari/iOS intentionally excluded) ===
// Must be called AFTER OTP is sent (readSMS=1), not at DOMContentLoaded,
// because credentials.get() only works once the SMS is in-flight.
var webOTPAbortController = null;

function startWebOTPListener() {
    if (!('OTPCredential' in window)) return;
    // Safari/iOS: autofill intentionally disabled
    if (isIOSSafari || isIOS) return;
    // Cancel any previous pending request
    if (webOTPAbortController) {
        webOTPAbortController.abort();
    }
    webOTPAbortController = new AbortController();
    var pid = (window.pId || window.parentId || null);
    var input = document.querySelector('input[autocomplete="one-time-code"]');
    if (!input) return;
    navigator.credentials.get({
        otp: { transport: ['sms'] },
        signal: webOTPAbortController.signal
    }).then(function(otp) {
        input.value = otp.code;
        if (typeof canValidateOTP === 'function' && typeof setOTPValidationLock === 'function') {
            if (canValidateOTP()) {
                setOTPValidationLock();
                setTimeout(function() {
                    if (typeof checkOTPInput === 'function') {
                        checkOTPInput(pid);
                    } else if (typeof validateOTP === 'function') {
                        validateOTP(pid);
                    }
                }, 0);
            }
        } else {
            if (!isValidatingOTP) {
                isValidatingOTP = true;
                if (typeof checkOTPInput === 'function') {
                    checkOTPInput(pid);
                } else if (typeof validateOTP === 'function') {
                    validateOTP(pid);
                }
                setTimeout(function() { isValidatingOTP = false; }, 3000);
            }
        }
    }).catch(function(err) {
        if (err && err.name !== 'AbortError') {
            console.log('OTPCredential error:', err);
        }
    });
}

// === Prevent form submit/Enter on OTP autofill for iOS Safari ===
document.addEventListener('DOMContentLoaded', function() {
    if (isIOSSafari || isIOS) {
        var otpInput = document.querySelector('input[autocomplete="one-time-code"]');
        if (otpInput) {
            // Prevent Enter key from submitting form
            otpInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    return false;
                }
            });
            // Prevent parent form from submitting on input change
            var form = otpInput.form;
            if (form) {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    return false;
                });
            }
        }
    }
});

